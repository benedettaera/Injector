-- Remote references
local codeRemote = game:GetService("ReplicatedStorage"):WaitForChild("ServerMsg"):WaitForChild("Code")
local souvenirRemote = game:GetService("ReplicatedStorage"):WaitForChild("Msg"):WaitForChild("RemoteFunction")

-- Helper: update status
local function setStatus(text)
	statusLabel.Text = text
end

-- Function to open boxes (extracted from previous open button logic)
local function openBoxesFromBag()
	local bag = player:FindFirstChild("Bag")
	if not bag then
		setStatus("Bag not found!")
		return
	end
	
	local boxItems = {}
	for _, child in ipairs(bag:GetChildren()) do
		if child:IsA("NumberValue") and child.Name:match("^16000%d+$") then
			local count = child.Value
			if count and count > 0 then
				table.insert(boxItems, {id = child.Name, count = count})
			end
		end
	end
	
	if #boxItems == 0 then
		setStatus("No NumberValue items with names starting with 16000 found in Bag.")
		return
	end
	
	setStatus("Found " .. #boxItems .. " box types. Opening...")
	
	local totalOpened = 0
	for _, item in ipairs(boxItems) do
		local id = tonumber(item.id)
		if id then
			for i = 1, item.count do
				pcall(function()
					souvenirRemote:InvokeServer("OpenSouvenirBox", id)
				end)
				totalOpened = totalOpened + 1
				task.wait(0.1)  -- delay between opens
			end
		end
	end
	
	setStatus("Opened " .. totalOpened .. " boxes.")
end

-- Claim Codes button handler
claimBtn.MouseButton1Click:Connect(function()
	-- Step 1: Claim codes
	setStatus("Claiming codes...")
	for _, code in ipairs(codes) do
		pcall(function()
			codeRemote:InvokeServer(code)
		end)
		task.wait(0.05)
	end
	setStatus("Codes claimed. Opening boxes...")
	
	-- Step 2: Open boxes
	task.spawn(function()
		openBoxesFromBag()
	end)
end)