-- Code list
local codes = {
	"FALLENSTAR", "BALI", "THANKSGIVING", "MOUNTRUSHMORE", "SYDNEY",
	"HALLOWEEN", "LUXURY", "SPOOKY", "TAIWAN", "SHANGHAI",
